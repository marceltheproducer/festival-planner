---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Festival Planner",
  description = "Plan your film festival submissions strategically. Browse festivals, track deadlines, and optimize your premiere status.",
} = Astro.props;

const siteName = "FestivalPlanner";
const pageTitle = title === "Home" ? `${siteName} — Smart Film Festival Submission Strategy` : `${title} | ${siteName}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site || "https://festivalplanner.app");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a12" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={new URL("/og-image.svg", canonicalUrl.origin).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/og-image.svg", canonicalUrl.origin).href} />

    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-film-950 text-film-100 flex flex-col antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
